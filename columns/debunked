// ======================================================
// 2. STATE
// ======================================================
let filtered = comments.slice();
let showingDetail = null;

// ======================================================
// 3. FILTERING
// ======================================================
function filterComments() {
  const dateVal   = document.getElementById("dateSearch").value;
  const topicVal  = document.getElementById("topicSearch").value.trim().toLowerCase();
  const seriesVal = document.getElementById("seriesSearch").value.trim().toLowerCase();

  filtered = comments.filter(c => {
    if (!c || !c.title) return false;

    const dateMatch = !dateVal || c.date === dateVal;

    const topicMatch = !topicVal || (
      (c.topic  && c.topic.toLowerCase().includes(topicVal)) ||
      (c.title  && c.title.toLowerCase().includes(topicVal)) ||
      (c.body   && c.body.toLowerCase().includes(topicVal))
    );

    const seriesMatch = !seriesVal || (
      c.series && c.series.toLowerCase().includes(seriesVal)
    );

    return dateMatch && topicMatch && seriesMatch;
  });

  showingDetail = null;
  renderList();
}

// ======================================================
// 4. LIST RENDER
// ======================================================
function renderList() {
  const list   = document.getElementById("commentList");
  const detail = document.getElementById("commentDetail");
  if (!list || !detail) return;

  detail.innerHTML = "";
  list.innerHTML = "";

  if (!filtered.length) {
    list.innerHTML = `<li><span class="comment-title">No entries found.</span></li>`;
    return;
  }

  filtered.forEach(c => {
    const li = document.createElement("li");
    li.onclick = () => showDetail(c);

    const snippet = c.body
      ? c.body.slice(0, 120) + (c.body.length > 120 ? "…" : "")
      : "";

    const topic  = c.topic  || "";
    const series = c.series || "";
    const date   = c.date   || "";

    const metaText = [topic, series ? `Series: ${series}` : "", date]
      .filter(Boolean).join(" • ");

    li.innerHTML = `
      <div class="comment-title">${escapeHtml(c.title || "")}</div>
      <div class="comment-meta">${escapeHtml(metaText)}</div>
      <div class="comment-body">${escapeHtml(snippet)}</div>
    `;
    list.appendChild(li);
  });
}

// ======================================================
// 5. DETAIL VIEW → POPUP MODAL
// ======================================================
function showDetail(c) {
  showingDetail = c;

  const backdrop = document.getElementById("modalBackdrop");
  const modal    = document.getElementById("articleModal");
  const titleEl  = document.getElementById("modalTitle");
  const metaEl   = document.getElementById("modalMeta");
  const bodyEl   = document.getElementById("modalBody");
  const linkRow  = document.getElementById("modalLinkRow");

  const topic  = c.topic  || "";
  const series = c.series || "";
  const date   = c.date   || "";

  const metaText = [topic, series ? `Series: ${series}` : "", date]
    .filter(Boolean).join(" • ");

  titleEl.textContent = c.title || "";
  metaEl.textContent  = metaText;
  bodyEl.textContent  = c.body || "";
  linkRow.innerHTML   = "";

  if (c.link) {
    const btn = document.createElement("button");
    btn.className = "open-link-btn";
    btn.textContent = "Open Full Article";
    btn.addEventListener("click", function(e) {
      e.stopPropagation();
      window.open(c.link, "_blank");
    });
    linkRow.appendChild(btn);
  }

  backdrop.classList.remove("hidden");
  modal.classList.remove("hidden");

  // Center the modal initially
  const rect = modal.getBoundingClientRect();
  const left = Math.max(14, (window.innerWidth - rect.width) / 2);
  const top  = Math.max(24, (window.innerHeight - rect.height) / 4);
  modal.style.left = left + "px";
  modal.style.top  = top  + "px";
}

function closeModal() {
  document.getElementById("modalBackdrop").classList.add("hidden");
  document.getElementById("articleModal").classList.add("hidden");
}

// ======================================================
// 6. DRAGGABLE MODAL
// ======================================================
let isDragging = false;
let dragOffsetX = 0;
let dragOffsetY = 0;

function initDrag() {
  const modal  = document.getElementById("articleModal");
  const header = document.getElementById("modalHeader");
  if (!modal || !header) return;

  header.addEventListener("mousedown", function(e) {
    isDragging = true;
    const rect = modal.getBoundingClientRect();
    dragOffsetX = e.clientX - rect.left;
    dragOffsetY = e.clientY - rect.top;
    e.preventDefault();
  });

  window.addEventListener("mousemove", function(e) {
    if (!isDragging) return;
    const modal = document.getElementById("articleModal");
    if (!modal) return;

    let left = e.clientX - dragOffsetX;
    let top  = e.clientY - dragOffsetY;

    const maxLeft = window.innerWidth  - modal.offsetWidth;
    const maxTop  = window.innerHeight - modal.offsetHeight;

    if (left < 7) left = 7;
    if (top  < 7) top  = 7;
    if (left > maxLeft - 7) left = maxLeft - 7;
    if (top  > maxTop  - 7) top  = maxTop  - 7;

    modal.style.left = left + "px";
    modal.style.top  = top  + "px";
  });

  window.addEventListener("mouseup", function() {
    isDragging = false;
  });
}

// ======================================================
// 7. UTILS
// ======================================================
function escapeHtml(str) {
  return String(str || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

// ======================================================
// 8. INIT
// ======================================================
filterComments();
initDrag();
</script>
